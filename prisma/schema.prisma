// Prisma schema — Gestão de Trading Esportivo

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TipoOperacao {
  Lay
  Back
  Trade
}

enum ResultadoOperacao {
  Green
  Red
  Anulado
}

enum LigaTipo {
  Liga
  Copa
  Continental
  Selecoes
}

model Metodo {
  id          String     @id @default(cuid())
  nome        String     @unique
  descricao   String?
  cor         String     @default("#facc15")
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  operacoes   Operacao[]
}

model Liga {
  id          String     @id @default(cuid())
  nome        String     @unique
  pais        String
  tipo        LigaTipo   @default(Liga)
  nivel       String?
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  times       Time[]
  operacoes   Operacao[]
}

model Time {
  id            String     @id @default(cuid())
  nome          String
  pais          String?
  abreviacao    String?
  ativo         Boolean    @default(true)
  ligaId        String?
  liga          Liga?      @relation(fields: [ligaId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  operacoesCasa Operacao[] @relation("TimeCasa")
  operacoesFora Operacao[] @relation("TimeFora")

  @@index([ligaId])
  @@index([nome])
}

model Operacao {
  id              String            @id @default(cuid())
  data            DateTime
  ligaId          String
  liga            Liga              @relation(fields: [ligaId], references: [id], onDelete: Restrict)
  timeCasaId      String
  timeCasa        Time              @relation("TimeCasa", fields: [timeCasaId], references: [id], onDelete: Restrict)
  timeForaId      String
  timeFora        Time              @relation("TimeFora", fields: [timeForaId], references: [id], onDelete: Restrict)
  mercado         String
  metodoId        String
  metodo          Metodo            @relation(fields: [metodoId], references: [id], onDelete: Restrict)
  tipo            TipoOperacao
  momento         String
  oddEntrada      Float
  oddSaida        Float?
  stake           Float
  responsabilidade Float?
  resultado       ResultadoOperacao
  lucro           Float
  observacoes     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([data])
  @@index([ligaId])
  @@index([metodoId])
  @@index([tipo])
}

model Configuracao {
  id                      Int      @id @default(autoincrement())
  bancaInicial            Float    @default(100)
  valorUnidade            Float    @default(50)
  stopLossDiario          Float    @default(5)
  stopGainDiario          Float    @default(8)
  stakePadraoPercent      Float    @default(2)
  maxOperacoesSimultaneas Int      @default(2)
  tema                    String   @default("dark")
  updatedAt               DateTime @updatedAt
}

model Meta {
  id                Int    @id @default(autoincrement())
  mes               String @unique // YYYY-MM
  metaLucroUnidades Float
  metaOperacoes     Int
}
