// Prisma schema — Gestão de Trading Esportivo (variante Postgres para produção)
//
// Espelha prisma/schema.prisma (SQLite, usado em desenvolvimento local) — os modelos devem
// ser mantidos idênticos nos dois arquivos. Só o datasource difere. Selecionado automaticamente
// pelo prisma.config.ts quando DATABASE_URL começa com "postgres". Veja o README (seção Deploy)
// para o passo a passo de uso na Vercel + Postgres/Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoOperacao {
  Lay
  Back
  Trade
}

enum ResultadoOperacao {
  Green
  Red
  Anulado
}

enum LigaTipo {
  Liga
  Copa
  Continental
  Selecoes
}

enum FaseOperacao {
  PreJogo
  AoVivo
}

enum StatusOperacao {
  Aberta
  Encerrada
}

enum ModoStake {
  Valor
  Percentual
}

model Metodo {
  id                    String     @id @default(cuid())
  nome                  String     @unique
  descricao             String?
  cor                   String     @default("#facc15")
  ativo                 Boolean    @default(true)
  usaBack               Boolean    @default(true)
  usaLay                Boolean    @default(true)
  stakesBack            Float?     @default(1)
  stakesLay             Float?     @default(1)
  criterioEntradaPadrao String?
  criterioSaidaPadrao   String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  operacoes             Operacao[]
}

model Liga {
  id          String     @id @default(cuid())
  nome        String     @unique
  pais        String
  tipo        LigaTipo   @default(Liga)
  nivel       String?
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  times       Time[]
  operacoes   Operacao[]
}

model Time {
  id            String     @id @default(cuid())
  nome          String
  pais          String?
  abreviacao    String?
  ativo         Boolean    @default(true)
  ligaId        String?
  liga          Liga?      @relation(fields: [ligaId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  operacoesCasa Operacao[] @relation("TimeCasa")
  operacoesFora Operacao[] @relation("TimeFora")

  @@index([ligaId])
  @@index([nome])
}

model Operacao {
  id                String             @id @default(cuid())
  data              DateTime
  ligaId            String
  liga              Liga               @relation(fields: [ligaId], references: [id], onDelete: Restrict)
  timeCasaId        String
  timeCasa          Time               @relation("TimeCasa", fields: [timeCasaId], references: [id], onDelete: Restrict)
  timeForaId        String
  timeFora          Time               @relation("TimeFora", fields: [timeForaId], references: [id], onDelete: Restrict)
  mercado           String
  metodoId          String
  metodo            Metodo             @relation(fields: [metodoId], references: [id], onDelete: Restrict)
  tipo              TipoOperacao
  momento           String
  fase              FaseOperacao       @default(PreJogo)
  minutoEntrada     Int?
  periodo           String?
  oddEntrada        Float
  oddSaida          Float?
  stake             Float
  responsabilidade  Float?
  criterioEntrada   String?
  criterioSaida     String?
  status            StatusOperacao     @default(Encerrada)
  resultado         ResultadoOperacao?
  lucro             Float?
  observacoes       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([data])
  @@index([ligaId])
  @@index([metodoId])
  @@index([tipo])
  @@index([status])
  @@index([fase])
}

model Configuracao {
  id                      Int       @id @default(autoincrement())
  bancaInicial            Float     @default(1000)
  stakeModo               ModoStake @default(Percentual)
  stakeValor              Float     @default(50)
  stakePercentual         Float     @default(2)
  stopLossDiario          Float     @default(50)
  stopGainDiario          Float     @default(80)
  maxOperacoesSimultaneas Int       @default(2)
  tema                    String    @default("dark")
  updatedAt               DateTime  @updatedAt
}

model Meta {
  id            Int    @id @default(autoincrement())
  mes           String @unique // YYYY-MM
  metaLucro     Float
  metaOperacoes Int
}
