# Desenvolvimento local (SQLite) — padrão, não precisa alterar:
DATABASE_URL="file:./dev.db"

# Produção (Postgres/Neon) — defina uma DATABASE_URL que comece com "postgres://" ou
# "postgresql://" (ex.: a connection string do Neon) na Vercel. O app detecta o prefixo
# automaticamente e troca o schema/datasource e as migrations para a variante Postgres.
# Veja o README (seção "Deploy na Vercel") para o passo a passo completo.
# DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"
